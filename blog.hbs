{{!< default}}

{{!-- Featured posts --}}
{{#foreach posts}}
    {{#if featured}}
        {{> "preview-blog" }}
        <div class="my-4 mx-auto w-4/5 rounded-full border-b lg:hidden last:hidden border-secondary"></div>
    {{/if}}
{{/foreach}}

{{!-- Everything else --}}
{{#foreach posts}}
    {{#unless featured}}
        {{> "preview-blog" }}
        <div class="my-4 mx-auto w-4/5 rounded-full border-b lg:hidden last:hidden border-secondary"></div>
    {{/unless}}
{{/foreach}}